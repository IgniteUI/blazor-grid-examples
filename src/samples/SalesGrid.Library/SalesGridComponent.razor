@using SalesGrid.Library.Services
@using SalesGrid.Library.Models
@using IgniteUI.Blazor.Controls
@inject SalesService SalesService
@implements IDisposable

<div class="container-fluid p-4 sales-dashboard">
    @if (isLoading)
    {
        <div class="text-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3">Loading sales data...</p>
        </div>
    }
    else if (!SalesService.Data.Any())
    {
        <div class="alert alert-warning" role="alert">
            No data available. Please check your connection.
        </div>
    }
    else
    {
        <div class="pivot-container">
            <div class="pivot-header mb-3">
                <h4>Sales Dashboard - Pivot Analysis</h4>
                <small class="text-muted">
                    <i class="bi bi-info-circle"></i> Drag and drop fields to analyze sales data by region, product, and time periods
                </small>
            </div>

            <div class="pivot-layout">
                <div class="pivot-selector-panel">
                    <IgbPivotDataSelector PivotGrid="pivotGrid" @ref="dataSelector">
                    </IgbPivotDataSelector>
                </div>

                <div class="pivot-grid-panel">
                    <IgbPivotGrid Data="SalesService.Data"
                                  @ref="pivotGrid"
                                  Height="calc(100vh - 300px)"
                                  AllowFiltering="true"
                                  DefaultExpandState="true"
                                  PivotConfiguration="@pivotConfiguration">
                    </IgbPivotGrid>
                </div>
            </div>

            <div class="mt-3">
                <small class="text-muted">
                    <i class="bi bi-info-circle"></i> Data updates every 3 seconds to simulate live sales data
                </small>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private System.Timers.Timer? updateTimer;
    private IgbPivotGrid? pivotGrid;
    private IgbPivotDataSelector? dataSelector;
    private IgbPivotConfiguration? pivotConfiguration;

    protected override async Task OnInitializedAsync()
    {
        SalesService.OnDataChanged += OnDataChanged;
        await SalesService.LoadDataAsync();

        // Configure pivot grid
        ConfigurePivotGrid();

        isLoading = false;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            // Start auto-update timer (every 3 seconds)
            updateTimer = new System.Timers.Timer(3000);
            updateTimer.Elapsed += (sender, args) =>
            {
                SalesService.UpdateAllData();
            };
            updateTimer.Start();
        }
    }

    private void ConfigurePivotGrid()
    {
        pivotConfiguration = new IgbPivotConfiguration();

        // Configure row dimensions (what we group by vertically)
        pivotConfiguration.Rows = new IgbPivotDimension[]
        {
            new IgbPivotDimension
            {
                MemberName = "Region",
                Enabled = true,
                DisplayName = "Region"
            },
            new IgbPivotDimension
            {
                MemberName = "Product",
                Enabled = true,
                DisplayName = "Product"
            }
        };

        // Configure column dimensions (what we pivot across horizontally)
        pivotConfiguration.Columns = new IgbPivotDimension[]
        {
            new IgbPivotDimension
            {
                MemberName = "Status",
                Enabled = true,
                DisplayName = "Status"
            }
        };

        // Configure value aggregations (what we measure)
        pivotConfiguration.Values = new IgbPivotValue[]
        {
            new IgbPivotValue
            {
                Member = "Value",
                Enabled = true,
                DisplayName = "Total Sales",
                Aggregate = new IgbPivotAggregator
                {
                    Key = "SUM",
                    Label = "Sum",
                    AggregatorName = PivotAggregationType.SUM
                }
            },
            new IgbPivotValue
            {
                Member = "Profit",
                Enabled = true,
                DisplayName = "Total Profit",
                Aggregate = new IgbPivotAggregator
                {
                    Key = "SUM",
                    Label = "Sum",
                    AggregatorName = PivotAggregationType.SUM
                }
            },
            new IgbPivotValue
            {
                Member = "Amount",
                Enabled = true,
                DisplayName = "Units Sold",
                Aggregate = new IgbPivotAggregator
                {
                    Key = "SUM",
                    Label = "Sum",
                    AggregatorName = PivotAggregationType.SUM
                }
            }
        };

        // Configure filter dimensions
        pivotConfiguration.Filters = new IgbPivotDimension[]
        {
            new IgbPivotDimension
            {
                MemberName = "SalesPerson",
                Enabled = false,
                DisplayName = "Sales Person"
            }
        };
    }

    private void OnDataChanged()
    {
        InvokeAsync(() =>
        {
            StateHasChanged();
            if (pivotGrid != null)
            {
                pivotGrid.MarkForCheck();
            }
        });
    }

    public void Dispose()
    {
        updateTimer?.Stop();
        updateTimer?.Dispose();
        SalesService.OnDataChanged -= OnDataChanged;
    }
}
