@using HRPortal.Library.Services
@using HRPortal.Library.Models
@using IgniteUI.Blazor.Controls
@inject HRService HRService
@implements IDisposable

<div class="container-fluid p-4">
    @if (isLoading)
    {
        <div class="text-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3">Loading employee data...</p>
        </div>
    }
    else if (!HRService.Data.Any())
    {
        <div class="alert alert-warning" role="alert">
            No data available. Please check your connection.
        </div>
    }
    else
    {
        <IgbTreeGrid Data="HRService.Data"
                     PrimaryKey="Id"
                     ForeignKey="ParentId"
                     AutoGenerate="false"
                     AllowFiltering="true"
                     FilterMode="@FilterMode.ExcelStyleFilter"
                     RowSelection="@GridSelectionMode.Multiple"
                     Height="calc(100vh - 200px)"
                     @ref="treeGrid">
            <IgbColumn Field="Name" Header="Employee Name" Width="18%" MinWidth="150px" Sortable="true" Resizable="true"></IgbColumn>
            <IgbColumn Field="Title" Header="Job Title" Width="18%" MinWidth="140px" Sortable="true" Resizable="true"></IgbColumn>
            <IgbColumn Field="Department" Header="Department" Width="10%" MinWidth="100px" Sortable="true" Resizable="true"></IgbColumn>
            <IgbColumn Field="Salary" Header="Salary" DataType="GridColumnDataType.Number" Width="9%" MinWidth="85px" Sortable="true" Resizable="true"></IgbColumn>
            <IgbColumn Field="HireDate" Header="Hire Date" DataType="GridColumnDataType.Date" Width="10%" MinWidth="95px" Sortable="true" Resizable="true"></IgbColumn>
            <IgbColumn Field="Status" Header="Status" Width="8%" MinWidth="80px" Sortable="true" Resizable="true"></IgbColumn>
            <IgbColumn Field="Manager" Header="Manager" Width="12%" MinWidth="100px" Sortable="true" Resizable="true"></IgbColumn>
            <IgbColumn Field="Location" Header="Location" Width="9%" MinWidth="85px" Sortable="true" Resizable="true"></IgbColumn>
            <IgbColumn Field="Performance" Header="Performance" DataType="GridColumnDataType.Number" Width="6%" MinWidth="90px" Sortable="true" Resizable="true"></IgbColumn>
        </IgbTreeGrid>
    }
</div>

@code {
    private bool isLoading = true;
    private IgbTreeGrid? treeGrid;

    protected override async Task OnInitializedAsync()
    {
        HRService.OnDataChanged += OnDataChanged;
        await HRService.LoadDataAsync();
        isLoading = false;
    }

    private void OnDataChanged()
    {
        InvokeAsync(() =>
        {
            StateHasChanged();
            if (treeGrid != null)
            {
                treeGrid.MarkForCheck();
            }
        });
    }

    public void Dispose()
    {
        HRService.OnDataChanged -= OnDataChanged;
    }
}
