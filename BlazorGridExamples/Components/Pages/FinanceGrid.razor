@page "/finance-grid"
@using BlazorGridExamples.Services
@using BlazorGridExamples.Models
@inject FinancialService FinancialService
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Financial Portfolio - Blazor Grid Examples</PageTitle>

<div class="container-fluid p-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h2 class="mb-0">Financial Portfolio</h2>
        </div>
        <div class="card-body">
            @if (isLoading)
            {
                <div class="text-center my-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-3">Loading financial data...</p>
                </div>
            }
            else if (!FinancialService.Data.Any())
            {
                <div class="alert alert-warning" role="alert">
                    No data available. Please check your connection.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped">
                        <thead class="table-dark">
                            <tr>
                                <th>Symbol</th>
                                <th>Asset</th>
                                <th>Last Price</th>
                                <th>Change %</th>
                                <th>Market Value</th>
                                <th>NET Profit</th>
                                <th>NET Profit %</th>
                                <th>Allocation</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in FinancialService.Data)
                            {
                                <tr>
                                    <td><strong>@item.Id</strong></td>
                                    <td>@item.HoldingName</td>
                                    <td>@item.Value?.CurrentPrice.ToString("C2")</td>
                                    <td class="@GetProfitLossClass(item.DailyPercentageChange)">
                                        <div class="d-flex align-items-center">
                                            @item.DailyPercentageChange.ToString("P2")
                                            @if (item.DailyPercentageChange >= 0)
                                            {
                                                <span class="ms-2">↑</span>
                                            }
                                            else
                                            {
                                                <span class="ms-2">↓</span>
                                            }
                                        </div>
                                    </td>
                                    <td>@item.MarketValue.ToString("C2")</td>
                                    <td class="@GetProfitLossClass(item.ProfitLossValue)">
                                        <div class="d-flex align-items-center">
                                            @item.ProfitLossValue.ToString("C2")
                                            @if (item.ProfitLossValue >= 0)
                                            {
                                                <span class="ms-2">↑</span>
                                            }
                                            else
                                            {
                                                <span class="ms-2">↓</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="@GetProfitLossClass(item.ProfitLossPercentage)">
                                        @item.ProfitLossPercentage.ToString("P2")
                                    </td>
                                    <td>@item.Allocation.ToString("P2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="mt-3">
                    <small class="text-muted">
                        <i class="bi bi-info-circle"></i> Data updates every 3 seconds to simulate live market data
                    </small>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .profit-condition {
        color: #28a745;
        font-weight: 600;
    }

    .loss-condition {
        color: #dc3545;
        font-weight: 600;
    }

    .table {
        font-size: 0.95rem;
    }

    .table thead th {
        font-weight: 600;
        border-bottom: 2px solid #dee2e6;
    }

    .table tbody tr:hover {
        background-color: #f8f9fa;
    }
</style>

@code {
    private bool isLoading = true;
    private System.Timers.Timer? updateTimer;

    protected override async Task OnInitializedAsync()
    {
        FinancialService.OnDataChanged += OnDataChanged;
        await FinancialService.LoadDataAsync();
        isLoading = false;

        // Start auto-update timer (every 3 seconds)
        updateTimer = new System.Timers.Timer(3000);
        updateTimer.Elapsed += (sender, args) =>
        {
            FinancialService.UpdateAllPrices();
        };
        updateTimer.Start();
    }

    private string GetProfitLossClass(double value)
    {
        return value >= 0 ? "profit-condition" : "loss-condition";
    }

    private void OnDataChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        updateTimer?.Stop();
        updateTimer?.Dispose();
        FinancialService.OnDataChanged -= OnDataChanged;
    }
}
