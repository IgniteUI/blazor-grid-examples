@page "/"

<PageTitle>Blazor Grid Examples</PageTitle>

<div class="container mt-5">
    <h1 class="mb-4">Blazor Grid Examples</h1>
    <p class="lead">Discover Blazor examples created with Ignite UI for Web Components. Explore advanced data grids, see real implementations, and learn best practices you can apply to your own apps.</p>
    
    <div class="row mt-5">
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Financial Portfolio</h5>
                    <p class="card-text">An example app showing assets, profit, and loss analyses with dynamic charts and a high-performance Data Grid.</p>
                    <a href="/finance-grid" class="btn btn-primary">View Example</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Sales Dashboard</h5>
                    <p class="card-text">Sales app example with summaries by region, product, and time periods using Pivot Grid.</p>
                    <a href="/sales-grid" class="btn btn-primary">View Example</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">HR Portal</h5>
                    <p class="card-text">Example featuring a Tree Grid to manage and display employee information.</p>
                    <a href="/hr-portal" class="btn btn-primary">View Example</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">ERP/Inventory</h5>
                    <p class="card-text">Sample app for ERP/Inventory handling large data volumes using Hierarchical Grid.</p>
                    <a href="/erp-hgrid" class="btn btn-primary">View Example</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Fleet Management</h5>
                    <p class="card-text">Sample app with a Master-Detail Grid for managing vehicle acquisition, operations, and maintenance.</p>
                    <a href="/fleet-management" class="btn btn-primary">View Example</a>
                </div>
            </div>
        </div>
    </div>
</div>
